// idem-stats — schema Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  pending
  active
  finished
  cancelled
}

enum MatchSource {
  extension
  web
  manual
}

enum FriendStatus {
  pending
  accepted
}

model User {
  id           String   @id @default(cuid())
  pseudo       String   @unique
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  // Solde de jetons : gagnés via les 1v1, dépensés au casino (blackjack).
  // 500 par défaut pour avoir de quoi tenter sa chance dès l'inscription.
  coins        Int      @default(500)

  matchesAsP1 Match[] @relation("MatchP1")
  matchesAsP2 Match[] @relation("MatchP2")
  wonMatches  Match[] @relation("MatchWinner")

  sentFriendRequests     Friendship[] @relation("FriendRequester")
  receivedFriendRequests Friendship[] @relation("FriendAddressee")

  sentMessages     Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageRecipient")
}

model Match {
  id         String      @id @default(cuid())
  game       String
  code       String?     @unique
  status     MatchStatus @default(pending)
  scoreP1    Int         @default(0)
  scoreP2    Int         @default(0)
  source     MatchSource?
  // Champ libre par jeu — pour le shifumi IRL : { winnerPick, loserPick, ... }.
  // Pour le shifumi REMOTE : { mode:'remote', creatorPick, opponentPick?, winnerPseudo?, ... }
  metadata   Json?
  createdAt  DateTime    @default(now())
  finishedAt DateTime?

  player1Id String
  player1   User   @relation("MatchP1", fields: [player1Id], references: [id])

  player2Id String?
  player2   User?   @relation("MatchP2", fields: [player2Id], references: [id])

  winnerId String?
  winner   User?   @relation("MatchWinner", fields: [winnerId], references: [id])

  @@index([status])
  @@index([game])
  @@index([player1Id])
  @@index([player2Id])
}

// Demande/relation d'amitié. Une seule ligne par couple (requester, addressee).
// Refus = suppression. Pas de "blocage" pour rester simple.
model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  requester   User         @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User         @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendStatus @default(pending)
  createdAt   DateTime     @default(now())
  acceptedAt  DateTime?

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
}

// Message 1:1 entre amis. Pas d'entité "Conversation" : la conversation entre
// A et B est l'ensemble des messages où {senderId, recipientId} = {A, B}.
// readAt = quand le destinataire a marqué la conversation comme lue.
model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("MessageSender",    fields: [senderId],    references: [id], onDelete: Cascade)
  recipientId String
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  body        String   @db.VarChar(2000)
  createdAt   DateTime @default(now())
  readAt      DateTime?

  // Sort court par fil + filtre non-lus du destinataire
  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, senderId, createdAt])
  @@index([recipientId, readAt])
}
