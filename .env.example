# ── Traefik (compose profile + routing) ───────────────────────────────
WEBSITE_NAME=idem-stats-api
DOMAIN_WEBSITE=api.idem.docker.localhost
ENTRYPOINT=web

# ── App ───────────────────────────────────────────────────────────────
# DATABASE_URL est défini dans docker-compose.yml (réseau interne "db:5432").
# Pas besoin de l'écraser ici sauf si tu utilises une DB externe.

# Auth
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_EXPIRES_IN=30d
BCRYPT_ROUNDS=10

# CORS — virgules pour plusieurs origines. Patterns supportés :
#   - exact            : http://idem.docker.localhost
#   - suffix wildcard  : chrome-extension://*
#   - prefix wildcard  : *.docker.localhost (matche n'importe quel sous-domaine docker.localhost en http ou https)
#   - "*" tout seul    : autorise tout (= mode dev permissif)
CORS_ORIGINS=*.docker.localhost,http://localhost:5173,chrome-extension://*

# Admin todo board — liste des pseudos admins séparés par des virgules
ADMIN_PSEUDOS=Mulien,Canigwestre
