# Postgres
DATABASE_URL=postgresql://idem:idem@db:5432/idem?schema=public

# Auth
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_EXPIRES_IN=30d
BCRYPT_ROUNDS=10

# Server
PORT=3000
NODE_ENV=development

# CORS — virgules pour plusieurs origines
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,chrome-extension://*

# Traefik host (dev)
API_HOST=api.idem.localhost
